{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "claude-flow": {
      "type": "local",
      "command": ["npx", "-y", "claude-flow@v3alpha", "mcp", "start"],
      "enabled": true
    },
    "ruv-swarm": {
      "type": "local",
      "command": ["npx", "-y", "ruv-swarm", "mcp", "start"],
      "enabled": true
    },
    "flow-nexus": {
      "type": "local",
      "command": ["npx", "-y", "flow-nexus@latest", "mcp", "start"],
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "description": "AI coding orchestrator that delegates tasks to specialist agents",
      "model": "opencode-go/glm-5",
      "mode": "primary"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "websearch": "allow",
    "question": "allow"
  }
}