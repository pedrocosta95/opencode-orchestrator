{
  "$schema": "https://opencode.ai/docs/hooks",
  "description": "Claude Flow hooks configuration - OpenCode compatible format. Maps V3 internal hook events to OpenCode-compatible hooks.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "description": "Session initialization hook - initializes session and restores context",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks session-start --session-id \"$SESSION_ID\" --load-context",
            "timeout": 10000,
            "continueOnError": true,
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "description": "Pre-edit hook for file modifications",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks pre-edit --file \"$TOOL_INPUT_file_path\"",
            "timeout": 5000,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "description": "Pre-command hook for bash execution",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks pre-command --command \"$TOOL_INPUT_command\"",
            "timeout": 3000,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^Task$",
        "description": "Pre-task hook for agent spawning (maps to pre-task event)",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks pre-task --description \"$(echo \"$TOOL_INPUT_description\" | head -c 200)\"",
            "timeout": 5000,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^(Grep|Glob|Read)$",
        "description": "Pre-search hook for caching",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks pre-search --query \"$TOOL_INPUT_pattern\"",
            "timeout": 2000,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^mcp__.*$",
        "description": "Pre-MCP hook for swarm coordination",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks mcp-pre --tool \"$TOOL_NAME\"",
            "timeout": 3000,
            "continueOnError": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "description": "Post-edit hook for formatting and learning (maps to post-edit event)",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks post-edit --file \"$TOOL_INPUT_file_path\" --success \"$TOOL_SUCCESS\" --train-patterns",
            "timeout": 5000,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "description": "Post-command hook for metrics (maps to post-command event)",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks post-command --command \"$TOOL_INPUT_command\" --success \"$TOOL_SUCCESS\" --exit-code \"$TOOL_EXIT_CODE\"",
            "timeout": 3000,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^Task$",
        "description": "Post-task hook for performance analysis (maps to post-task event)",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks post-task --task-id \"$TOOL_RESULT_agent_id\" --success \"$TOOL_SUCCESS\" --analyze-performance",
            "timeout": 5000,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^(Grep|Glob|Read)$",
        "description": "Post-search hook for caching results",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks post-search --query \"$TOOL_INPUT_pattern\" --cache-results",
            "timeout": 2000,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^mcp__.*$",
        "description": "Post-MCP hook for coordination state",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks mcp-post --tool \"$TOOL_NAME\" --success \"$TOOL_SUCCESS\"",
            "timeout": 3000,
            "continueOnError": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "description": "Session end hook - evaluates if task is complete and persists state (maps to session-end event)",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks session-end --generate-summary true --persist-state true --export-metrics true",
            "timeout": 10000,
            "continueOnError": true,
            "async": false
          }
        ]
      }
    ],
    "Notification": [
      {
        "description": "Handle notifications with swarm status",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-flow@alpha hooks notify --message \"$NOTIFICATION_MESSAGE\" --swarm-status",
            "timeout": 3000,
            "continueOnError": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^mcp__claude-flow__.*$",
        "description": "Auto-allow claude-flow MCP tools",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"decision\": \"allow\", \"reason\": \"claude-flow MCP tool auto-approved\"}'",
            "timeout": 1000
          }
        ]
      }
    ]
  },
  "v3HookMapping": {
    "_comment": "Maps V3 internal hook events to OpenCode-compatible hooks",
    "PreTaskExecute": "PreToolUse (matcher: Task)",
    "PostTaskExecute": "PostToolUse (matcher: Task)",
    "PreCommand": "PreToolUse (matcher: Bash)",
    "PostCommand": "PostToolUse (matcher: Bash)",
    "PreEdit": "PreToolUse (matcher: Edit|Write)",
    "PostEdit": "PostToolUse (matcher: Edit|Write)",
    "PreRead": "PreToolUse (matcher: Read)",
    "PostRead": "PostToolUse (matcher: Read)",
    "PreSearch": "PreToolUse (matcher: Grep|Glob)",
    "PostSearch": "PostToolUse (matcher: Grep|Glob)",
    "SessionStart": "SessionStart",
    "SessionEnd": "Stop",
    "SessionPause": "SessionStart (matcher: compact)",
    "SessionResume": "SessionStart (matcher: resume)",
    "PreAgentSpawn": "PreToolUse (matcher: Task)",
    "PostAgentSpawn": "PostToolUse (matcher: Task)",
    "PreAgentTerminate": "Stop",
    "PostAgentTerminate": "Stop",
    "PreMemoryStore": "PreToolUse (matcher: Bash)",
    "PostMemoryStore": "PostToolUse (matcher: Bash)",
    "PreMemoryRetrieve": "PreToolUse (matcher: Read|Grep)",
    "PostMemoryRetrieve": "PostToolUse (matcher: Read|Grep)",
    "OnError": "Notification",
    "OnWarning": "Notification",
    "PreRoute": "SessionStart",
    "PostRoute": "PostToolUse"
  },
  "opencodeNotes": {
    "eventNaming": "OpenCode uses PascalCase event names (e.g., SessionStart, PreToolUse)",
    "matcherFormat": "OpenCode uses regex matchers for tool names",
    "asyncSupport": "Set async: false for critical hooks that must complete before proceeding",
    "environmentVariables": "OpenCode provides TOOL_INPUT_*, TOOL_SUCCESS, TOOL_EXIT_CODE, SESSION_ID variables"
  }
}
